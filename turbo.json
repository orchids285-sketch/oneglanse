{
	"$schema": "https://turbo.build/schema.json",
	"tasks": {
		"build": {
			"dependsOn": ["^build"],
			"outputs": ["dist/**", ".next/**", "!.next/cache/**"]
		},

		"dev": {
			"dependsOn": ["^build"],
			"cache": false,
			"persistent": true
		},

		"typecheck": {
			"dependsOn": ["^build"],
			"outputs": []
		},

		"lint": {
			"outputs": []
		},

		"test": {
			"dependsOn": ["^build"],
			"cache": false
		},

		"clean": {
			"cache": false
		}
	}
}
