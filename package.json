{
	"name": "oneglanse",
	"private": true,
	"scripts": {
		"build": "turbo build",
		"deploy:web": "pnpm deploy --filter @oneglanse/web --prod /app/out",
		"dev": "turbo dev",
		"dev:web": "turbo dev --filter=@oneglanse/web",
		"dev:agent": "turbo dev --filter=@oneglanse/agent",
		"lint": "turbo lint",
		"typecheck": "turbo typecheck",
		"clean": "turbo clean && rm -rf node_modules",
		"db:generate": "pnpm --filter @oneglanse/db db:generate",
		"db:migrate": "pnpm --filter @oneglanse/db db:migrate",
		"db:push": "pnpm --filter @oneglanse/db db:push",
		"db:studio": "pnpm --filter @oneglanse/db db:studio",
		"start:agent": "pnpm --filter=@oneglanse/agent start",
		"start:worker": "pnpm --filter=@oneglanse/agent start:worker",
		"lint:fix": "biome check . --fix"
	},
	"devDependencies": {
		"@biomejs/biome": "1.9.4",
		"turbo": "^2.3.3",
		"typescript": "^5.9.3"
	},
	"packageManager": "pnpm@10.16.0",
	"engines": {
		"node": ">=20"
	}
}
