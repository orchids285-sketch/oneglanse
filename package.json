{
	"name": "oneglanse",
	"description": "The open-source GEO and AI visibility tracker",
	"license": "MIT",
	"homepage": "https://oneglanse.com",
	"repository": {
		"type": "git",
		"url": "https://github.com/aryamantodkar/oneglanse"
	},
	"private": true,
	"scripts": {
		"build": "turbo build",
		"dev": "turbo dev",
		"dev:web": "turbo dev --filter=@oneglanse/web",
		"dev:landing": "turbo dev --filter=@oneglanse/landing",
		"dev:agent": "turbo dev --filter=@oneglanse/agent",
		"local": "node scripts/run-local.mjs",
		"auth": "node scripts/run-auth.mjs",
		"upload:vps": "node scripts/run-auth.mjs --upload-existing-only",
		"self-host": "node scripts/run-compose.mjs bootstrap",
		"self-host:build": "node scripts/run-compose.mjs up -d --build",
		"self-host:pull": "node scripts/run-compose.mjs pull --ignore-buildable",
		"lint": "turbo lint",
		"typecheck": "turbo typecheck",
		"clean": "turbo clean && rm -rf node_modules",
		"db:generate": "pnpm --filter @oneglanse/db db:generate",
		"db:migrate": "pnpm --filter @oneglanse/db db:migrate",
		"db:push": "pnpm --filter @oneglanse/db db:push",
		"db:studio": "pnpm --filter @oneglanse/db db:studio",
		"start:worker": "pnpm --filter=@oneglanse/agent start:worker",
		"lint:fix": "biome check . --fix"
	},
	"devDependencies": {
		"@biomejs/biome": "1.9.4",
		"knip": "^5.85.0",
		"turbo": "^2.3.3",
		"typescript": "^5.9.3"
	},
	"packageManager": "pnpm@10.16.0",
	"engines": {
		"node": ">=20"
	}
}
