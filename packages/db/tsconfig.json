{
	"extends": "../../tsconfig.json",
	"compilerOptions": {
		/* 🚨 OVERRIDES */
		"module": "NodeNext",
		"moduleResolution": "NodeNext",
		"noEmit": false,
		"isolatedModules": true,
		"composite": true,
		"baseUrl": "../../",
		"paths": {
			"@oneglanse/types": [
				"packages/types/src/index.ts",
				"packages/types/dist/index.d.ts"
			]
		},

		/* Output */
		"rootDir": "./src",
		"outDir": "./dist",
		"declaration": true,
		"declarationMap": true
	},
	"include": ["src/**/*.ts"],
	"exclude": ["node_modules", "dist"],
	"references": [{ "path": "../types" }]
}
