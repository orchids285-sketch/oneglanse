# Redis (local)
REDIS_HOST=redis
REDIS_PORT=6379

# Proxy: configure only the split PROXY_* fields below.
# Supported schemes: http, https, socks4, socks5
# PROXY_PROVIDER=generic
# Supported providers:
# generic, decodo, smartproxy, brightdata, oxylabs, thordata,
# lunaproxy, netnut, soax, scrapeops, proxyempire, iproyal, webshare
#
# Start from the base endpoint/credentials from your provider dashboard.
# The agent rewrites only the documented sticky-session token for the provider.
#
# Decodo / Smartproxy:
# For sticky-port endpoints, the agent picks one random documented sticky port
# per provider run and reuses it for that browser session.
# Recommended browser scheme from Decodo browser/tool docs: HTTP.
# PROXY_PROVIDER=decodo
# PROXY_SCHEME=http
# PROXY_HOST=us.decodo.com
# PROXY_PORT=10001
# PROXY_USERNAME=user-abc
# PROXY_PASSWORD=pass-abc
# Alternative gate.decodo.com session form:
# PROXY_SCHEME=http
# PROXY_HOST=gate.decodo.com
# PROXY_PORT=7000
# PROXY_USERNAME=user-abc-session-old-sessionduration-30
# PROXY_PASSWORD=pass-abc
#
# Bright Data:
# Bright Data session ids must stay alphanumeric; the agent rewrites only the
# session token.
# Recommended browser scheme from Bright Data integration docs: HTTP.
# PROXY_PROVIDER=brightdata
# PROXY_SCHEME=http
# PROXY_HOST=brd.superproxy.io
# PROXY_PORT=33335
# PROXY_USERNAME=brd-customer-CUSTOMER-zone-ZONE-session-old
# PROXY_PASSWORD=password
#
# Oxylabs:
# For sticky-port endpoints, start from a documented sticky seed port such as
# 10001/20001/30001/40001. The agent keeps one random sticky port for the lease.
# Recommended browser scheme from Oxylabs browser integration docs: HTTP.
# PROXY_PROVIDER=oxylabs
# PROXY_SCHEME=http
# PROXY_HOST=us-pr.oxylabs.io
# PROXY_PORT=10001
# PROXY_USERNAME=customer-USERNAME
# PROXY_PASSWORD=PASSWORD
# If your username already includes -sessid-..., the agent replaces that token too.
#
# Thordata:
# ThorData:
# Add the API URL from your ThorData dashboard. The agent fetches the proxy
# list on each launch, picks one random proxy, and ensures concurrent workers
# do not reuse the same proxy at the same time.
# PROXY_PROVIDER=thordata
# PROXY_SCHEME=http
# THORDATA_PROXY_API_URL=https://get-ip.thordata.net/api?td-customer=YOUR_CUSTOMER_ID&sesstype=1&number=5&country=US
#
# LunaProxy:
# sessid is rewritten to a 12-character token; existing sesstime is preserved.
# If your dashboard gives you a dedicated host, keep that host as-is.
# Recommended browser/tool scheme from LunaProxy guides: HTTP.
# PROXY_PROVIDER=lunaproxy
# PROXY_SCHEME=http
# PROXY_HOST=rw.lunaproxy.com
# PROXY_PORT=12233
# PROXY_USERNAME=user-USERNAME-region-us-sessid-old-sesstime-10
# PROXY_PASSWORD=password
#
# NetNut:
# Use the dashboard-generated base username and let the agent append/replace sid.
# Recommended default from NetNut docs: HTTP.
# PROXY_PROVIDER=netnut
# PROXY_SCHEME=http
# PROXY_HOST=gw.netnut.net
# PROXY_PORT=5959
# PROXY_USERNAME=USERNAME-res-us
# PROXY_PASSWORD=password
#
# SOAX:
# Recommended browser/web automation scheme from SOAX docs: HTTP.
# PROXY_PROVIDER=soax
# PROXY_SCHEME=http
# PROXY_HOST=proxy.soax.com
# PROXY_PORT=5000
# PROXY_USERNAME=package-12345-country-us-sessionid-old-sessionlength-300
# PROXY_PASSWORD=password
#
# ScrapeOps:
# Recommended scheme from ScrapeOps proxy examples: HTTP.
# PROXY_PROVIDER=scrapeops
# PROXY_SCHEME=http
# PROXY_HOST=residential-proxy.scrapeops.io
# PROXY_PORT=8181
# PROXY_USERNAME=scrapeops.sticky_session=7
# PROXY_PASSWORD=API_KEY
#
# ProxyEmpire:
# Use your dashboard-generated username; the agent appends/replaces an 8-digit sid.
# Recommended browser/web automation scheme: HTTP.
# PROXY_PROVIDER=proxyempire
# PROXY_SCHEME=http
# PROXY_HOST=res.proxyempire.io
# PROXY_PORT=9000
# PROXY_USERNAME=your-dashboard-username
# PROXY_PASSWORD=password
#
# IPRoyal:
# Sticky session tokens live in the password.
# Recommended browser/web automation scheme from IPRoyal examples: HTTP.
# PROXY_PROVIDER=iproyal
# PROXY_SCHEME=http
# PROXY_HOST=geo.iproyal.com
# PROXY_PORT=12321
# PROXY_USERNAME=username
# PROXY_PASSWORD=password_country-US_session-old_lifetime-10m
#
# Webshare:
# Webshare stickiness is selected on the provider side; credentials are passed through.
# Recommended browser/web automation scheme: HTTP.
# PROXY_PROVIDER=webshare
# PROXY_SCHEME=http
# PROXY_HOST=p.webshare.io
# PROXY_PORT=80
# PROXY_USERNAME=username
# PROXY_PASSWORD=password
PROXY_SCHEME=http
PROXY_HOST=127.0.0.1
PROXY_PORT=8080
# PROXY_USERNAME=your-username
# PROXY_PASSWORD=your-password

# Optional explicit Python binary when camoufox is not installed on `python3`
# CAMOUFOX_PYTHON_BIN=python3.11

# Browser mode: `virtual` starts headful Firefox on Xvfb, `headful` uses an
# existing DISPLAY, `headless` runs true headless.
CAMOUFOX_HEADLESS_MODE=virtual

# Xvfb settings used when CAMOUFOX_HEADLESS_MODE=virtual.
CAMOUFOX_XVFB_DISPLAY=:99
CAMOUFOX_XVFB_SCREEN=1920x1080x24

# Enable humanized mouse movement. Set max time to 0 to disable.
CAMOUFOX_HUMANIZE=true
# Humanized cursor movement max time in seconds. Set to 0 to disable.
CAMOUFOX_HUMANIZE_MAX_TIME_S=1.5
# CAMOUFOX_GEOIP=true
# CAMOUFOX_GEOIP_DB=MaxMind
# CAMOUFOX_OS=["windows","macos"]
# CAMOUFOX_LOCALE=["en-US","en-GB","en"]
# CAMOUFOX_FONTS=["Arial","Helvetica Neue"]
# CAMOUFOX_ADDONS=[]
# CAMOUFOX_EXCLUDE_ADDONS=["UBO"]
# CAMOUFOX_SCREEN={"min_width":1366,"max_width":1920,"min_height":768,"max_height":1080}
# CAMOUFOX_WINDOW=[1366,768]
# CAMOUFOX_WEBGL_CONFIG — leave unset; Camoufox picks a coherent WebGL fingerprint
# CAMOUFOX_BROWSER=official/prerelease
# CAMOUFOX_FF_VERSION=135
# CAMOUFOX_CONFIG_JSON={}
# CAMOUFOX_FINGERPRINT_JSON — leave unset; forces a coherent real-device fingerprint
CAMOUFOX_FINGERPRINT_PRESET=true
# CAMOUFOX_FIREFOX_USER_PREFS_JSON={}
# CAMOUFOX_ENV_JSON={}
# CAMOUFOX_ARGS=["--width=1366","--height=768"]
# CAMOUFOX_EXECUTABLE_PATH=/custom/camoufox/firefox
# CAMOUFOX_MAIN_WORLD_EVAL=false
# CAMOUFOX_ENABLE_CACHE=false
# CAMOUFOX_BLOCK_IMAGES=false
# CAMOUFOX_BLOCK_WEBRTC=false
# CAMOUFOX_BLOCK_WEBGL=false
# CAMOUFOX_DISABLE_COOP=false
# CAMOUFOX_CUSTOM_FONTS_ONLY=false
# CAMOUFOX_I_KNOW_WHAT_IM_DOING=false
# CAMOUFOX_DEBUG=false
# CAMOUFOX_EXTRA_LAUNCH_JSON={}

DEBUG_ENABLED=false
