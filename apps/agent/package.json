{
	"name": "@oneglanse/agent",
	"version": "1.0.0",
	"private": true,
	"type": "module",
	"description": "Local agent that runs a real browser to execute LLM prompts",
	"scripts": {
		"dev": "node --loader ts-node/esm src/index.ts",
		"start:worker": "node dist/worker.js",
		"build": "tsc",
		"typecheck": "tsc --noEmit"
	},
	"dependencies": {
		"@oneglanse/errors": "workspace:*",
		"@oneglanse/services": "workspace:*",
		"@oneglanse/types": "workspace:*",
		"@oneglanse/utils": "workspace:*",
		"bullmq": "^5.66.4",
		"dotenv": "^17.2.3",
		"playwright": "^1.57.0",
		"turndown": "^7.2.2",
		"zod": "^3.24.1"
	},
	"devDependencies": {
		"@types/node": "^25.0.3",
		"@types/turndown": "^5.0.6",
		"ts-node": "^10.9.2",
		"typescript": "^5.9.3"
	}
}
