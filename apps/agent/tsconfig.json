{
	"extends": "../../tsconfig.json",
	"compilerOptions": {
		"module": "NodeNext",
		"moduleResolution": "NodeNext",

		"rootDir": "src",
		"outDir": "dist",

		"noEmit": false,
		"isolatedModules": true,
		"composite": true,

		"strict": true,
		"esModuleInterop": true,
		"skipLibCheck": true
	},
	"include": ["src/**/*.ts", "../../packages/errors/src/lib/classifyError.ts", "../../packages/utils/src/agent/backoff.ts"],
	"references": [
		{ "path": "../../packages/types" },
		{ "path": "../../packages/errors" },
		{ "path": "../../packages/utils" },
		{ "path": "../../packages/services" }
	]
}
