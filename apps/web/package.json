		"@oneglanse/types": "workspace:*",
		"@oneglanse/ui": "workspace:*",
		"@oneglanse/utils": "workspace:*",
		"@t3-oss/env-nextjs": "^0.12.0",
		"@tanstack/react-query": "^5.69.0",
