# Local app defaults used by `pnpm local` and `pnpm auth`
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/oneglanse
CLICKHOUSE_URL=http://127.0.0.1:8123
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=redis
APP_URL=http://127.0.0.1:3000
API_BASE_URL=http://127.0.0.1:3000

# Docker service defaults used by `pnpm self-host`
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=oneglanse
CLICKHOUSE_DB=oneglanse
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=clickhouse

# App secrets
BETTER_AUTH_SECRET=o1Gk9Q2mR7xL4vP8sN6dF3hT5yC1uJ0wB4eK7aM2p
OPENAI_API_KEY=

